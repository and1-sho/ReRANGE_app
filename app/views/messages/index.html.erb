<div class="requests-page">
  <header class="requests-header">
    <%= link_to app_home_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__name">Re:RANGE</span>
    <% end %>

    <div class="requests-account">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <main class="notifications-main">
    <h1 class="notifications-heading">メッセージ</h1>
    <% if current_user.trainer? %>
      <p class="messages-lead">あなた宛のリクエストが届いています。一覧には表示されません。</p>
    <% else %>
      <p class="messages-lead">トレーナー宛てに送ったリクエストです。一覧には表示されません。</p>
    <% end %>

    <% if @requests.any? %>
      <div class="requests-list">
        <% @requests.each do |request| %>
          <article class="request-card">
            <%= link_to profile_path_for(request.user), class: "request-card__avatar-link", aria: { label: "#{request.user.name}のプロフィールへ移動" } do %>
              <%= render "shared/user_avatar_icon", variant: :card %>
            <% end %>
            <div class="request-card__body">
              <div class="request-card__header">
                <span class="request-card__name"><%= link_to request.user.name, profile_path_for(request.user) %></span>
                <span class="request-card__dot">・</span>
                <time class="request-card__date" datetime="<%= request.created_at.iso8601 %>" title="<%= social_time_title(request.created_at) %>">
                  <%= social_time_ago(request.created_at) %>
                </time>
              </div>

              <h2 class="request-card__title">
                <%= link_to request.title, request_path(request) %>
              </h2>

              <% if request.video.attached? %>
                <div class="request-card__thumb-wrap" data-controller="feed-video">
                  <%= video_tag url_for(request.video),
                        class: "request-card__thumb-video",
                        playsinline: true,
                        muted: true,
                        controls: true,
                        preload: "metadata",
                        poster: (request.video_thumbnail.attached? ? url_for(request.video_thumbnail) : nil),
                        data: {
                          feed_video_target: "video",
                          action: "loadedmetadata->feed-video#layout"
                        },
                        aria: { label: "リクエスト動画（#{request.title}）" } %>
                </div>
              <% end %>
              <%= render "requests/request_card_actions", request: request %>
            </div>
          </article>
        <% end %>
      </div>
    <% else %>
      <p class="requests-empty">メッセージはまだありません</p>
    <% end %>

    <p class="request-compose__footer-link">
      <%= link_to "投稿一覧に戻る", requests_path, class: "menu-btn menu-btn--ghost" %>
    </p>
  </main>
</div>
