<div class="dashboard-page">
  <header class="requests-header">
    <%= link_to app_home_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__name">Re:RANGE</span>
    <% end %>

    <div class="requests-account">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <main class="dashboard-main">
    <h1 class="dashboard-title">ダッシュボード</h1>
    <div class="dashboard-grid">
      <% if current_user.member? %>
        <%= link_to trainers_path, class: "dashboard-card" do %>
          <div class="dashboard-card__header">
            <h2 class="dashboard-card__title">トレーナーを探す</h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="dashboard-card__icon" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
            </svg>
          </div>
          <p class="dashboard-card__text">自分に合ったトレーナーを見つけて、リクエストを送ってみましょう</p>
        <% end %>

        <%= link_to new_request_path, class: "dashboard-card" do %>
          <div class="dashboard-card__header">
            <h2 class="dashboard-card__title">リクエストを投稿する</h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="dashboard-card__icon" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
            </svg>
          </div>
          <p class="dashboard-card__text">動画や質問を投稿して、さまざまなトレーナーからアドバイスをもらいましょう。</p>
        <% end %>

        <%= link_to requests_path, class: "dashboard-card" do %>
          <div class="dashboard-card__header">
            <h2 class="dashboard-card__title">投稿一覧を見る</h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="dashboard-card__icon" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
          </div>
          <p class="dashboard-card__text">他に投稿された動画や質問を見ることができます</p>
        <% end %>

        <%= link_to messages_path, class: "dashboard-card" do %>
          <div class="dashboard-card__header">
            <h2 class="dashboard-card__title">メッセージ</h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="dashboard-card__icon" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <p class="dashboard-card__text">トレーナー宛てに送ったリクエストはこちら</p>
        <% end %>
      <% else %>
        <%= link_to requests_path, class: "dashboard-card" do %>
          <div class="dashboard-card__header">
            <h2 class="dashboard-card__title">投稿一覧を見る</h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="dashboard-card__icon" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
            </svg>
          </div>
          <p class="dashboard-card__text">他に投稿された動画や質問を見ることができます</p>
        <% end %>

        <%= link_to messages_path, class: "dashboard-card" do %>
          <div class="dashboard-card__header">
            <h2 class="dashboard-card__title">メッセージ</h2>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="dashboard-card__icon" aria-hidden="true" focusable="false">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </div>
          <p class="dashboard-card__text">あなた宛のリクエストが届いています。一覧には出ません。</p>
        <% end %>
      <% end %>
    </div>
  </main>
</div>
