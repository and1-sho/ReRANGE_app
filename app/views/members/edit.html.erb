<div class="public-profile-edit">
  <div class="public-profile-edit__body">
    <h1 class="public-profile-edit__title">プロフィール編集</h1>

    <% if @member.errors.any? %>
      <div class="public-profile-edit__errors">
        <p class="public-profile-edit__errors-title">入力内容を確認してください</p>
        <ul>
          <% @member.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @member, url: member_path(@member), method: :patch, local: true, class: "public-profile-edit__form" do |f| %>
      <div class="public-profile-edit__field">
        <%= f.label :header_image, "ヘッダー画像", class: "auth-label" %>
        <% if @member.header_image.attached? %>
          <p class="public-profile-edit__current-file">現在の画像: <%= @member.header_image.filename.to_s %></p>
          <label class="public-profile-edit__remove-check">
            <%= check_box_tag "user[remove_header_image]", "1", false %>
            ヘッダー画像を削除する
          </label>
        <% else %>
          <p class="public-profile-edit__current-file">現在の画像: 未設定</p>
        <% end %>
        <%= f.file_field :header_image, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :avatar_image, "プロフィール画像", class: "auth-label" %>
        <% if @member.avatar_image.attached? %>
          <p class="public-profile-edit__current-file">現在の画像: <%= @member.avatar_image.filename.to_s %></p>
          <label class="public-profile-edit__remove-check">
            <%= check_box_tag "user[remove_avatar_image]", "1", false %>
            プロフィール画像を削除する
          </label>
        <% else %>
          <p class="public-profile-edit__current-file">現在の画像: 未設定</p>
        <% end %>
        <%= f.file_field :avatar_image, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :profile_affiliation, "所属", class: "auth-label" %>
        <%= f.text_field :profile_affiliation, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :profile_prefecture, "都道府県", class: "auth-label" %>
        <%= f.select :profile_prefecture, User::PREFECTURES, { include_blank: "選択してください" }, class: "auth-input auth-select" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :profile_area_detail, "市区町村", class: "auth-label" %>
        <%= f.text_field :profile_area_detail, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :birth_date, "誕生日", class: "auth-label" %>
        <%= f.date_field :birth_date, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :boxing_started_on, "選手開始日", class: "auth-label" %>
        <%= f.date_field :boxing_started_on, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :stance, "スタンス", class: "auth-label" %>
        <%= f.select :stance, User::STANCES, { include_blank: "選択してください" }, class: "auth-input auth-select" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :weight_class, "階級", class: "auth-label" %>
        <%= f.select :weight_class, User::WEIGHT_CLASSES, { include_blank: "選択してください" }, class: "auth-input auth-select" %>
      </div>

      <div class="public-profile-edit__field">
        <%= f.label :profile_bio, "プロフィール", class: "auth-label" %>
        <%= f.text_area :profile_bio, rows: 6, class: "auth-input" %>
      </div>

      <div class="public-profile-edit__actions">
        <%= link_to "戻る", member_path(@member), class: "menu-btn menu-btn--ghost" %>
        <%= f.submit "保存する", class: "menu-btn menu-btn--primary" %>
      </div>
    <% end %>
  </div>
</div>
