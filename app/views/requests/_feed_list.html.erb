<% requests_list = local_assigns.key?(:requests) ? local_assigns[:requests] : @requests %>
<% empty_message =
     if local_assigns.key?(:empty_copy)
       local_assigns[:empty_copy]
     elsif user_signed_in? && current_user.trainer? && params[:filter] == "advised_by_me"
       "フィードバックしたリクエストはまだありません"
     else
       "公開のリクエストはまだありません"
     end %>
<% empty_title = local_assigns[:empty_title] %>
<% empty_subcopy = local_assigns[:empty_subcopy] %>
<% empty_class = local_assigns[:empty_class] %>
<% if requests_list.any? %>
  <div class="requests-list-box">
    <% requests_list.each do |request| %>
      <article
        class="request-card"
        data-controller="request-feed-card"
        data-request-feed-card-detail-url-value="<%= request_path(request) %>"
      >
        <%= link_to profile_path_for(request.user), class: "request-card__avatar-link", aria: { label: "#{request.user.name}のプロフィールへ移動" } do %>
          <%= render "shared/user_avatar_icon", variant: :card %>
        <% end %>
        <div class="request-card__body">
          <div class="request-card__header">
            <div class="request-card__header-main">
              <span class="request-card__name"><%= link_to request.user.name, profile_path_for(request.user) %></span>
              <span class="request-card__dot">・</span>
              <time class="request-card__date" datetime="<%= request.created_at.iso8601 %>" title="<%= social_time_title(request.created_at) %>">
                <%= social_time_ago(request.created_at) %>
              </time>
            </div>
            <% if user_signed_in? && current_user.member? && request.user_id == current_user.id %>
              <details class="request-card__overflow" data-controller="details-dismiss">
                <summary class="request-card__overflow-trigger" aria-label="投稿のメニュー">
                  <span class="request-card__overflow-dots" aria-hidden="true">⋯</span>
                </summary>
                <div class="request-card__overflow-panel">
                  <%= link_to "編集", request_path(request, edit_request: "1", anchor: "request-edit"), class: "request-card__overflow-item" %>
                  <%= link_to "削除", request_path(request), class: "request-card__overflow-item request-card__overflow-item--danger",
                        data: { turbo_method: :delete, turbo_confirm: "このリクエストを削除しますか？" } %>
                </div>
              </details>
            <% end %>
          </div>

          <h2 class="request-card__title">
            <% if request.directed_to_trainer_id.present? %>
              <span class="request-card__visibility-icon" aria-label="非公開リクエスト" title="非公開リクエスト">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                </svg>
              </span>
            <% end %>
            <%= link_to request.title, request_path(request) %>
          </h2>

          <% if request.video.attached? %>
            <div class="request-card__thumb-wrap" data-controller="feed-video">
              <%= video_tag url_for(request.video),
                    class: "request-card__thumb-video",
                    playsinline: true,
                    muted: true,
                    controls: true,
                    preload: "metadata",
                    poster: (request.video_thumbnail.attached? ? url_for(request.video_thumbnail) : nil),
                    data: {
                      feed_video_target: "video",
                      action: "loadedmetadata->feed-video#layout"
                    },
                    aria: { label: "リクエスト動画（#{request.title}）" } %>
            </div>
          <% end %>
          <%= render "requests/request_card_actions", request: request %>
        </div>
      </article>
    <% end %>
  </div>
<% else %>
  <% if empty_title.present? %>
  <div class="requests-empty <%= empty_class %>">
    <p class="requests-empty__title"><%= empty_title %></p>
    <p class="requests-empty__subcopy"><%= empty_subcopy %></p>
  </div>
<% else %>
  <p class="requests-empty <%= empty_class %>"><%= empty_message %></p>
<% end %>
<% end %>
