<div class="requests-page">
  <header class="requests-header">
    <%= link_to root_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__mark"></span>
      <span class="requests-brand__name">Re:RANGE</span>
    <% end %>

    <div class="requests-account">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <main class="request-compose">
    <% if @request.errors.any? %>
      <div class="request-compose__errors" role="alert">
        <ul>
          <% @request.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @request, local: true, html: { class: "request-compose__form" } do |f| %>
      <div class="request-compose__row">
        <div class="request-compose__avatar-slot" aria-hidden="true">
          <%= render "shared/user_avatar_icon", variant: :card %>
        </div>

        <div class="request-compose__fields">
          <%= f.text_field :title, placeholder: "例）パンチ力を上げたい", class: "request-compose__title", autocomplete: "off" %>

          <%= f.text_area :body, placeholder: "例）パンチ力を上げるにはどういうトレーニングをしたらいいですか？", rows: 8, class: "request-compose__body" %>

          <div class="request-compose__video" data-controller="video-upload-preview">
            <%= f.label :video, "動画（任意）", class: "request-compose__video-label" %>
            <p class="request-compose__video-hint">MP4 / MOV・1本あたり100MBまで。差し替えは新しいファイルを選ぶか、削除にチェック。</p>
            <% if @request.video.attached? %>
              <p class="request-compose__video-current">
                現在の動画: <%= @request.video.filename.to_s %>
              </p>
              <label class="request-compose__video-remove">
                <%= check_box_tag "request[remove_video]", "1", false %>
                動画を削除する
              </label>
            <% end %>
            <%= f.file_field :video,
                  accept: "video/mp4,video/quicktime,.mp4,.mov",
                  class: "request-compose__video-input",
                  data: {
                    "video-upload-preview-target" => "input",
                    action: "change->video-upload-preview#preview"
                  } %>
            <div class="request-compose__video-preview" data-video-upload-preview-target="box" hidden>
              <p class="request-compose__video-preview-label">選択中の動画</p>
              <video data-video-upload-preview-target="player" controls playsinline class="request-compose__video-preview-player"></video>
            </div>
          </div>
        </div>
      </div>

      <div class="request-compose__toolbar">
        <%= link_to "キャンセル", request_path(@request), class: "request-compose__cancel" %>
        <%= f.submit "更新する", class: "menu-btn menu-btn--primary request-compose__submit" %>
      </div>
    <% end %>

    <p class="request-compose__footer-link">
      <%= link_to "一覧に戻る", requests_path, class: "menu-btn menu-btn--ghost" %>
    </p>
  </main>
</div>
