<div class="requests-page-content requests-show">

  <header class="site-header">
    <%= link_to app_home_path, class: "site-header__brand" do %>
      <span class="site-header__logo">Re:RANGE</span>
    <% end %>

    <div class="site-header__actions">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <main class="layout">
    <% if current_user.member? || current_user.trainer? %>
      <% sidebar_partial = current_user.member? ? "member_sidebar" : "trainer_sidebar" %>
      <%= render sidebar_partial %>

      <div class="layout__inner">
        <%= render(current_user.member? ? "member_sidebar" : "trainer_sidebar") %>

        <div class="layout__main">

          <!-- 投稿 -->
          <article class="request">

            <!-- 投稿一覧に戻る -->
            <%= link_to requests_path, class: "request-show__back-pill", aria: { label: "投稿一覧に戻る" } do %>
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="request-show__back-arrow" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
              </svg>
            <% end %>

            <!-- 投稿ヘッダー -->
            <header class="request__header">
              <div class="request__author">
                <%= link_to profile_path_for(@request.user), class: "request-show__avatar-link", aria: { label: "#{@request.user.name}のプロフィールへ移動" } do %>
                  <%= render "shared/user_avatar_icon", variant: :card %>
                <% end %>
                <span class="request__name">
                  <%= link_to @request.user.name, profile_path_for(@request.user) %>
                </span>
                <span class="request__dot">·</span>
                <time class="request__date" datetime="<%= @request.created_at.iso8601 %>" title="<%= social_time_title(@request.created_at) %>">
                  <%= social_time_ago(@request.created_at) %>
                </time>
              </div>

              <!-- 投稿のメニュー -->
              <% if current_user.member? && @request.user_id == current_user.id && !@editing_request %>
                <details class="request__menu" data-controller="details-dismiss">
                  <summary class="request__menu-trigger" aria-label="投稿のメニュー">
                    <span class="request__menu-dots" aria-hidden="true">⋯</span>
                  </summary>
                  <div class="request__menu-panel">
                    <%= link_to "編集", request_path(@request, edit_request: "1", anchor: "request-edit"), class: "request__menu-item" %>
                    <%= link_to "削除", request_path(@request), class: "request__menu-item request__menu-item--danger",
                      data: { turbo_method: :delete, turbo_confirm: "このリクエストを削除しますか？" } %>
                  </div>
                </details>
              <% end %>
            </header>

            <!-- 投稿本文 -->
            <div class="request__body<%= " request__body--editing" if @editing_request %>"<%= " data-controller=\"request-edit-media\"" if @editing_request %>>
              <h1 class="request__title">
                <% if @request.directed_to_trainer_id.present? %>
                  <span class="request__visibility-icon" aria-label="非公開リクエスト" title="非公開リクエスト">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="16" height="16" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
                    </svg>
                  </span>
                <% end %>
                <span><%= @request.title %></span>
              </h1>

              <% if @request.video.attached? %>
                <div class="request__video">
                  <%= render "shared/video_aspect", url: url_for(@request.video), wrapper_class: "video-aspect--request-show" %>
                  <% if @editing_request %>
                    <button type="button" class="request__video-remove" data-action="click->request-edit-media#remove" onclick="(function(btn){var input=document.getElementById('request_remove_video'); if(input){input.checked=true; input.dispatchEvent(new Event('change',{bubbles:true}));} var wrap=btn.closest('.request__video'); if(wrap){wrap.style.display='none';}})(this)" aria-label="動画を削除">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    </button>
                  <% end %>
                </div>
              <% end %>

              <div class="request__text">
                <%= simple_format(@request.body) %>
              </div>
            </div>

            <!-- エンゲージメント -->
            <div class="request__meta">
              <span class="request__comments">
                <%= @request.advice_count %>件のアドバイス
              </span>
            </div>

          </article>

          <!-- アドバイス一覧 -->
          <section class="advice-list">

            <% @request.advices.each do |advice| %>
              <article class="advice">

                <!-- アドバイスヘッダー -->
                <header class="advice__header">
                  <%= link_to profile_path_for(advice.user), class: "advice__avatar" do %>
                    <%= render "shared/user_avatar_icon", variant: :card %>
                  <% end %>

                  <span class="advice__name">
                    <%= link_to advice.user.name, profile_path_for(advice.user) %>
                  </span>

                  <time class="advice__date" datetime="<%= advice.created_at.iso8601 %>">
                    <%= social_time_ago(advice.created_at) %>
                  </time>
                </header>

                <!-- 本文 -->
                <div class="advice__body">
                  <%= simple_format(advice.body) %>
                </div>

                <% if advice.video.attached? %>
                  <div class="advice__media">
                    <%= render "shared/video_aspect", url: url_for(advice.video) %>
                  </div>
                <% end %>

              </article>
            <% end %>

          </section>

          <!-- 投稿フォーム -->
          <% if current_user.trainer? %>
            <section class="advice-form">
              <%= form_with model: Advice.new, url: request_advices_path(@request) do |f| %>

                <%= f.text_area :body, placeholder: "アドバイスを書く", class: "advice-form__field" %>

                <div class="advice-form__actions">
                  <%= f.file_field :video %>
                  <%= f.submit "投稿" %>
                </div>

              <% end %>
            </section>
          <% end %>

        </div>
      </div>

    <% end %>
  </main>

</div>
