<div class="requests-page-content requests-show">

  <header class="site-header">
    <div class="site-header__account-actions">
      <%= render "shared/account_menu" %>
    </div>
    <%= link_to app_home_path, class: "site-header__brand-logo" do %>
      <img class="logo-img" src="/images/logo/logo-main.png" alt="10K">
    <% end %>
  </header>

  <main class="layout">
    <% if current_user.member? || current_user.trainer? %>
      <% sidebar_partial = current_user.member? ? "member_sidebar" : "trainer_sidebar" %>

      <div class="layout__inner">
        <%= render "requests/#{sidebar_partial}" %>

        <div class="layout__main">
          <div class="layout__main-inner">

            <!-- 投稿 -->
            <article class="request">

              <!-- 投稿一覧に戻る -->
              <%= link_to requests_path, class: "request__back-btn", aria: { label: "投稿一覧に戻る" } do %>
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="request__back-arrow" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
                </svg>
              <% end %>

              <!-- 投稿ヘッダー -->
              <header class="request-card__header">
                <div class="request-card__header-main">
                  <span class="request-show__avatar-link">
                    <%= render "shared/user_avatar_icon", variant: :card %>
                  </span>

                  <span class="request-card__name">
                  <%= @request.user.name %>
                  </span>
                  <span class="request-card__dot">·</span>
                  <time class="request-card__date" datetime="<%= @request.created_at.iso8601 %>" title="<%= social_time_title(@request.created_at) %>">
                    <%= social_time_ago(@request.created_at) %>
                  </time>
                </div>

              </header>

              <!-- 投稿本文 -->
              <div class="request__body">
                <h1 class="request__title">
                  <span><%= @request.title %></span>
                </h1>

                <% if @request.video.attached? %>
                  <div class="request__video">
                    <%= render "shared/video_aspect", url: url_for(@request.video), wrapper_class: "video-aspect--request-show" %>
                  </div>
                <% end %>

                <div class="request__text">
                  <%= simple_format(@request.body) %>
                  <% if @request.edited? %>
                    <p class="request__edited-mark">（編集済み）</p>
                  <% end %>
                </div>
              </div>
            </article>

            <hr class="request__divider" />

            <!-- アドバイス一覧 -->
            <section class="advice-list" id="request-advice" aria-labelledby="advice-region-label">

              <span id="advice-region-label" class="request__sr-only">アドバイス</span>
              <% advice_list = @request.advices.select(&:persisted?).sort_by(&:created_at).reverse %>
              <% if advice_list.any? %>
                <% advice_list.each do |advice| %>
                  <article class="advice-item">

                    <!-- アドバイスヘッダー -->
                    <header class="advice-card__header">
                      <div class="advice-card__header-main">
                        <span class="advice__avatar">
                          <%= render "shared/user_avatar_icon", variant: :card %>
                        </span>
                        <span class="advice-card__name">
                          <%= advice.user.name %>
                        </span>
                        <span class="request-card__dot">·</span>
                        <time class="advice-card__date" datetime="<%= advice.created_at.iso8601 %>" title="<%= social_time_title(advice.created_at) %>">
                          <%= social_time_ago(advice.created_at) %>
                        </time>
                      </div>
                    </header>

                    <!-- 本文 -->
                    <div class="advice__body">
                      <%= simple_format(advice.body) %>
                      <% if advice.edited? %>
                        <p class="request__edited-mark">（編集済み）</p>
                      <% end %>
                    </div>

                    <% if advice.video.attached? %>
                      <div class="request__video-wrap request__video-wrap--advice">
                        <%= render "shared/video_aspect", url: url_for(advice.video), wrapper_class: "video-aspect--request-show" %>
                      </div>
                    <% end %>
                  </article>
                <% end %>
              <% end %>

              <% can_compose_inline = current_user.trainer? && (@request.directed_to_trainer_id.blank? || @request.directed_to_trainer_id == current_user.id) && @request.advices.none? { |advice| advice.user_id == current_user.id } %>
              <% if can_compose_inline %>
                <% advice_form = @inline_advice || Advice.new %>
                  <div class="request__inline-compose<%= " request__inline-compose--after-list" if advice_list.any? %>" data-controller="inline-compose">
                  <%= form_with model: advice_form, url: request_advices_path(@request), local: true, html: { class: "request__inline-compose-form", multipart: true }, data: {
                  controller: "request-polish",
                  "request-polish-endpoint-value": polish_request_advices_path(@request),
                  "request-polish-max-attempts-value": 2,
                  "request-polish-remaining-attempts-value": @remaining_inline_advice_polish_attempts || 2,
                  "request-polish-draft-token-value": @inline_advice_polish_draft_token,
                  "request-polish-min-body-length-value": 8,
                  "request-polish-body-only-value": true
                } do |f| %>
                  <%= hidden_field_tag :advice_polish_draft_token, @inline_advice_polish_draft_token %>
                  <div class="request__inline-video-preview" data-inline-compose-target="preview" hidden>
                    <video class="request__inline-video-preview-media" data-inline-compose-target="previewVideo" playsinline muted preload="metadata"></video>
                    <span class="request__inline-video-duration" data-inline-compose-target="duration"></span>
                    <button type="button" class="request__inline-video-remove" data-action="inline-compose#removeMedia" aria-label="動画を削除">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg>
                    </button>
                  </div>
                  <%= f.text_area :body,
                    rows: 1,
                    placeholder: "アドバイスを書く",
                    class: "request__inline-compose-field",
                    data: {
                      inline_compose_target: "field",
                      "request-polish-target": "body",
                      action: "focus->inline-compose#expand input->inline-compose#onInput input->request-polish#onBodyInput"
                    } %>
                  <p class="request-compose__polish-error" data-request-polish-target="error" hidden></p>
                  <div class="request-compose__proposal request-compose__proposal--modern" data-request-polish-target="proposal" hidden>
                    <p class="request-compose__proposal-label">AIからの提案</p>
                    <p class="request-compose__proposal-body" data-request-polish-target="proposalBody"></p>
                    <div class="request-compose__proposal-actions">
                      <button type="button" class="menu-btn menu-btn--primary" data-action="request-polish#adopt">提案を反映する</button>
                    </div>
                  </div>
                  <% if advice_form.errors.any? %>
                    <div class="request__inline-compose-errors" role="alert">
                      <ul>
                        <% advice_form.errors.full_messages.each do |message| %>
                          <li><%= message %></li>
                        <% end %>
                      </ul>
                    </div>
                  <% end %>
                  <div class="request__inline-compose-actions" data-inline-compose-target="actions"<%= " hidden" unless advice_form.errors.any? %>>
                    <%= f.file_field :video,
                      accept: "video/mp4,video/quicktime,.mp4,.mov",
                      class: "request__inline-file-input",
                      id: "inline_advice_video_input",
                      data: {
                        inline_compose_target: "videoInput",
                        action: "change->inline-compose#onMediaChange"
                      } %>
                    <label class="request__inline-media" for="inline_advice_video_input" aria-label="動画をアップロード">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
                      </svg>
                    </label>
                    <button type="button" class="request__advice-editor-polish" data-request-polish-target="polishButton" data-action="request-polish#polish" disabled>文章を整える</button>
                    <button type="button" class="request__inline-cancel" data-action="inline-compose#cancel">キャンセル</button>
                    <%= f.submit "投稿", class: "request__inline-submit" %>
                  </div>

                  <% end %>
                </div>
              <% elsif advice_list.blank? %>
                <p class="request__advice-empty">まだアドバイスはありません</p>
              <% end %>
            </section>

            <!-- 投稿フォーム -->
            <div class="requests-feed-aside-spacer" aria-hidden="true"></div>
          </div>
          <%= render "shared/requests_feed_aside" %>
        </div>
      </div>

    <% end %>
  </main>

</div>
