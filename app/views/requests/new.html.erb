<h1>リクエスト作成</h1>
<%= form_with model: @request, local: true do |f| %>
  <div>
    <%= f.label :title, "タイトル" %><br>
    <%= f.text_field :title %>
  </div>
  <div>
    <%= f.label :body, "内容" %><br>
    <%= f.text_area :body %>
  </div>
  <div>
    <%= f.submit "作成する" %>
  </div>
<% end %>

<p><%= link_to "一覧に戻る", requests_path %></p>
