<div class="requests-page layout-feed page-requests-new">
  <div class="requests-feed-chrome">
    <%= link_to app_home_path, class: "requests-feed-chrome__brand" do %>
      <span class="requests-feed-chrome__brand-name">Re:RANGE</span>
    <% end %>
    <div class="requests-feed-chrome__actions">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </div>

  <div class="requests-feed-body">
    <div class="requests-trainer-layout">
      <%= render "member_sidebar" %>

      <div class="requests-trainer-main">
        <div class="requests-feed-stage requests-feed-stage--compose-gap">
          <div class="requests-feed-column requests-feed-column--stream">
            <% unless current_user.member_profile_completed? %>
              <div class="profile-reminder">
                <p class="profile-reminder__text">プロフィールを設定と、トレーナーがあなたの状況を理解しやすくなります。</p>
                <%= link_to "プロフィールを設定", edit_member_path(current_user), class: "menu-btn menu-btn--primary" %>
              </div>
            <% end %>

            <main class="request-compose request-compose--modern">
              <h1 class="request-compose__page-heading">新規リクエスト</h1>
              <% request_visibility = params[:request_visibility].presence || "public" %>
              <% is_private_visibility = request_visibility == "private" %>

              <% if @request.errors.any? %>
                <div class="request-compose__errors" role="alert">
                  <ul>
                    <% @request.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>

              <%= form_with model: @request, local: true, html: { class: "request-compose__form request-compose__form--modern" }, data: {
                controller: "request-polish request-visibility",
                "request-polish-endpoint-value": polish_requests_path,
                "request-polish-max-attempts-value": 2,
                "request-polish-remaining-attempts-value": @remaining_polish_attempts,
                "request-polish-draft-token-value": @request_polish_draft_token,
                "request-polish-min-body-length-value": 8
              } do |f| %>
                <%= hidden_field_tag :request_polish_draft_token, @request_polish_draft_token %>

                <div class="request-compose__visibility--modern" data-action="change->request-visibility#sync">
                  <div class="request-compose__visibility-options">
                    <label class="request-compose__visibility-option">
                      <%= radio_button_tag :request_visibility, "public", !is_private_visibility, id: "request_visibility_public" %>
                      <span class="request-compose__visibility-option-text">
                        <span class="request-compose__visibility-option-title">公開</span>
                        <span class="request-compose__visibility-option-desc">全員のリクエスト一覧に表示されます</span>
                      </span>
                    </label>
                    <label class="request-compose__visibility-option">
                      <%= radio_button_tag :request_visibility, "private", is_private_visibility,
                            id: "request_visibility_private",
                            data: { request_visibility_target: "privateRadio" } %>
                      <span class="request-compose__visibility-option-text">
                        <span class="request-compose__visibility-option-title">非公開</span>
                        <span class="request-compose__visibility-option-desc">選択したトレーナーだけが内容を閲覧できます</span>
                      </span>
                    </label>
                  </div>
                  <div
                    class="request-compose__visibility-trainer<%= " request-compose__visibility-trainer--hidden" unless is_private_visibility %>"
                    data-request-visibility-target="trainerWrapper"
                  >
                    <%= f.label :directed_to_trainer_id, "トレーナーを選択してください", class: "request-compose__field-label", for: "request_directed_to_trainer_id" %>
                    <%= f.select :directed_to_trainer_id,
                          options_from_collection_for_select(@trainers, :id, :name, @request.directed_to_trainer_id),
                          { include_blank: "選択してください" },
                          id: "request_directed_to_trainer_id",
                          class: "request-compose__visibility-select",
                          disabled: !is_private_visibility,
                          data: { request_visibility_target: "trainerSelect" } %>
                  </div>
                </div>

                <div
                  class="request-compose__title-block"
                  data-controller="compose-char-counter"
                  data-compose-char-counter-max-value="24"
                >
                  <label class="request-compose__field-label" for="request_title">タイトル</label>
                  <div class="request-compose__title-pill">
                    <%= f.text_field :title,
                          maxlength: 24,
                          id: "request_title",
                          placeholder: "例）パンチ力について",
                          class: "request-compose__title-input",
                          autocomplete: "off",
                          data: {
                            compose_char_counter_target: "field",
                            request_polish_target: "title",
                            action: "input->compose-char-counter#sync"
                          } %>
                  </div>
                  <p class="request-compose__title-meta" aria-live="polite">
                    <span data-compose-char-counter-target="count">0</span><span class="request-compose__field-meta-max">/24</span>
                  </p>
                </div>

                <div
                  class="request-compose__body-block"
                  data-controller="compose-char-counter"
                  data-compose-char-counter-max-value="300"
                >
                  <label class="request-compose__field-label" for="request_body">本文</label>
                  <%= f.text_area :body,
                        id: "request_body",
                        maxlength: 300,
                        placeholder: "例）パンチ力を上げるにはどういうトレーニングをしたらいいですか？",
                        rows: 8,
                        class: "request-compose__body request-compose__body--modern",
                        data: {
                          compose_char_counter_target: "field",
                          request_polish_target: "body",
                          action: "input->compose-char-counter#sync input->request-polish#onBodyInput"
                        } %>
                  <p class="request-compose__body-meta" aria-live="polite">
                    <span data-compose-char-counter-target="count">0</span><span class="request-compose__field-meta-max">/300</span>
                  </p>
                </div>

                <div class="request-compose__polish-panel">
                  <div class="request-compose__polish-actions">
                    <button type="button" class="request-compose__polish-pill" data-request-polish-target="polishButton" data-action="request-polish#polish" disabled>文章を整える</button>
                    
                  </div>
                  <p class="request-compose__polish-error" data-request-polish-target="error" hidden></p>

                  <div class="request-compose__proposal request-compose__proposal--modern" data-request-polish-target="proposal" hidden>
                    <p class="request-compose__proposal-label">AIからの提案</p>
                    <p class="request-compose__proposal-title" data-request-polish-target="proposalTitle"></p>
                    <p class="request-compose__proposal-body" data-request-polish-target="proposalBody"></p>
                    <div class="request-compose__proposal-actions">
                      <button type="button" class="menu-btn menu-btn--primary" data-action="request-polish#adopt">提案を反映する</button>
                    </div>
                  </div>
                </div>

                <div class="request-compose__video-block" data-controller="video-upload-preview">
                  <%= f.file_field :video,
                        accept: "video/mp4,video/quicktime,.mp4,.mov",
                        class: "request-compose__video-input-hidden",
                        id: "request_video_input",
                        data: {
                          "video-upload-preview-target" => "input",
                          action: "change->video-upload-preview#preview"
                        } %>
                  <div
                    class="request-compose__video-drop"
                    data-video-upload-preview-target="dropzone"
                    data-action="click->video-upload-preview#openFilePicker keydown->video-upload-preview#onDropzoneKeydown dragover->video-upload-preview#onDragOver:prevent dragleave->video-upload-preview#onDragLeave drop->video-upload-preview#onDrop:prevent"
                    role="button"
                    tabindex="0"
                    aria-controls="request_video_input"
                  >
                    <p class="request-compose__video-drop-text">動画をドラッグ＆ドロップするか、クリックしてアップロード</p>
                    <div class="request-compose__video-drop-icon" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="request-compose__video-drop-svg" width="28" height="28">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
                      </svg>
                    </div>
                  </div>
                  <p class="request-compose__video-hint request-compose__video-hint--modern">MP4 / MOV・1本あたり100MBまで（任意）</p>
                  <div class="request-compose__video-preview request-compose__video-preview--modern" data-video-upload-preview-target="box" hidden>
                    <p class="request-compose__video-preview-label">選択中の動画</p>
                    <div class="video-aspect video-aspect--compose-preview" data-controller="video-aspect">
                      <video data-video-upload-preview-target="player" data-video-aspect-target="video" data-action="loadedmetadata->video-aspect#layout" controls playsinline class="video-aspect__media"></video>
                    </div>
                  </div>
                </div>

                <div class="request-compose__toolbar request-compose__toolbar--modern">
                  <%= link_to "キャンセル", requests_path, class: "request-compose__cancel request-compose__cancel--pill" %>
                  <%= f.submit "投稿", class: "menu-btn menu-btn--primary request-compose__submit request-compose__submit--pill" %>
                </div>
              <% end %>
            </main>
          </div>
          <div class="requests-feed-aside-spacer" aria-hidden="true"></div>
        </div>
        <%= render "shared/requests_feed_aside" %>
      </div>
    </div>
  </div>
</div>
