<div class="requests-page-content requests-new">

  <!-- ヘッダー -->
  <%= render "shared/header" %>

  <div class="layout">

    <div class="layout__inner">
      <%= render "member_sidebar" %>

      <div class="layout__main">
        <div class="layout__main-inner">
          <!-- 新規リクエスト -->
          <main class="request-new__main">
            <h1 class="request-new__main-title">新規リクエスト</h1>
            <% request_visibility = params[:request_visibility].presence || "public" %>
            <% is_private_visibility = request_visibility == "private" %>

            <% if @request.errors.any? %>
              <div class="request-new__error-message" role="alert">
                <ul>
                  <% @request.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            <% end %>

            <%= form_with model: @request, local: true, html: { class: "request-new__form" }, data: {
              controller: "request-polish request-visibility",
              "request-polish-endpoint-value": polish_requests_path,
              "request-polish-max-attempts-value": 2,
              "request-polish-remaining-attempts-value": @remaining_polish_attempts,
              "request-polish-draft-token-value": @request_polish_draft_token,
              "request-polish-min-body-length-value": 8
            } do |f| %>
              <%= hidden_field_tag :request_polish_draft_token, @request_polish_draft_token %>

              <!-- タイトル -->
              <div
                class="request-new__form-block title-block"
                data-controller="compose-char-counter"
                data-compose-char-counter-max-value="24"
              >
                <label class="request-new__field-title" for="request_title">タイトル</label>
                <%= f.text_field :title,
                  maxlength: 24,
                  id: "request_title",
                  placeholder: "例）パンチ力について",
                  class: "request-new__field-input",
                  autocomplete: "off",
                  data: {
                    compose_char_counter_target: "field",
                    request_polish_target: "title",
                    action: "input->compose-char-counter#sync"
                  } %>
                <p class="request-new__title-meta" aria-live="polite">
                  <span data-compose-char-counter-target="count">0</span><span class="request-new__field-meta-max">/24</span>
                </p>
              </div>

              <!-- 本文 -->
              <div
                class="request-compose__form-block body-block"
                data-controller="compose-char-counter"
                data-compose-char-counter-max-value="300"
              >
                <label class="request-new__field-title" for="request_body">本文</label>
                <%= f.text_area :body,
                  id: "request_body",
                  maxlength: 300,
                  placeholder: "例）パンチ力を上げるにはどういうトレーニングをしたらいいですか？",
                  rows: 8,
                  class: "request-new__field-input",
                  data: {
                    compose_char_counter_target: "field",
                    request_polish_target: "body",
                    action: "input->compose-char-counter#sync input->request-polish#onBodyInput"
                  } %>
                <p class="request-new__body-meta" aria-live="polite">
                  <span data-compose-char-counter-target="count">0</span><span class="request-new__field-meta-max">/300</span>
                </p>
              </div>

              <div class="ai-suggestion_polish-block">
                <div class="ai-suggestion__polish-actions">
                  <button type="button" class="ai-suggestion__polish-pill" data-request-polish-target="polishButton" data-action="request-polish#polish" disabled>文章を整える</button>
                </div>
                <p class="ai-suggestion__polish-error" data-request-polish-target="error" hidden></p>

                <div class="ai-suggestion__proposal" data-request-polish-target="proposal" hidden>
                  <p class="ai-suggestion__proposal-label">AIからの提案</p>
                  <p class="ai-suggestion__proposal-title" data-request-polish-target="proposalTitle"></p>
                  <p class="ai-suggestion__proposal-body" data-request-polish-target="proposalBody"></p>
                  <div class="ai-suggestion__proposal-actions">
                    <button type="button" class="menu-btn menu-btn--primary" data-action="request-polish#adopt">提案を反映する</button>
                  </div>
                </div>
              </div>

              <div class="request-new__video-block" data-controller="video-upload-preview">
                <%= f.file_field :video,
                      accept: "video/mp4,video/quicktime,.mp4,.mov",
                      class: "request-new__video-input-hidden",
                      id: "request_video_input",
                      data: {
                        "video-upload-preview-target" => "input",
                        action: "change->video-upload-preview#preview"
                      } %>
                <div
                  class="request-new__video-drop"
                  data-video-upload-preview-target="dropzone"
                  data-action="click->video-upload-preview#openFilePicker keydown->video-upload-preview#onDropzoneKeydown dragover->video-upload-preview#onDragOver:prevent dragleave->video-upload-preview#onDragLeave drop->video-upload-preview#onDrop:prevent"
                  role="button"
                  tabindex="0"
                  aria-controls="request_video_input"
                >
                  <p class="request-new__video-drop-text">動画をドラッグ＆ドロップするか、<br>クリックしてアップロード</p>
                  <div class="request-new__video-drop-icon" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="request-new__video-drop-svg" width="28" height="28">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 16.5V9.75m0 0 3 3m-3-3-3 3M6.75 19.5a4.5 4.5 0 0 1-1.41-8.775 5.25 5.25 0 0 1 10.233-2.33 3 3 0 0 1 3.758 3.848A3.752 3.752 0 0 1 18 19.5H6.75Z" />
                    </svg>
                  </div>
                </div>
                <p class="request-new__video-hint">MP4 / MOV・1本あたり100MBまで（任意）</p>
                <div class="request-new__video-preview request-new__video-preview--modern" data-video-upload-preview-target="box" hidden>
                  <p class="request-new__video-preview-label">選択中の動画</p>
                  <div class="video-aspect__preview" data-controller="video-aspect">
                    <video data-video-upload-preview-target="player" data-video-aspect-target="video" data-action="loadedmetadata->video-aspect#layout" controls playsinline class="video-aspect__media"></video>
                  </div>
                </div>
              </div>

              <div class="request-new__btn-box">
                <%= link_to "キャンセル", requests_path, class: "request-new__btn-cancel" %>
                <%= f.submit "投稿", class: "menu-btn request-new__btn-submit" %>
              </div>
            <% end %>
          </main>
        </div>
        <div class="requests-feed-aside-spacer" aria-hidden="true"></div>
        <%= render "shared/requests_feed_aside" %>
      </div>
    </div>
  </div>
</div>
