<div class="requests-page">
  <header class="requests-header">
    <%= link_to app_home_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__name">Re:RANGE</span>
    <% end %>

    <div class="requests-account">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <main class="request-compose">
    <% if @request.errors.any? %>
      <div class="request-compose__errors" role="alert">
        <ul>
          <% @request.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: @request, local: true, html: { class: "request-compose__form" }, data: {
      controller: "request-polish",
      "request-polish-endpoint-value": polish_requests_path,
      "request-polish-max-attempts-value": 2,
      "request-polish-remaining-attempts-value": @remaining_polish_attempts,
      "request-polish-draft-token-value": @request_polish_draft_token,
      "request-polish-min-body-length-value": 8
    } do |f| %>
      <%= hidden_field_tag :request_polish_draft_token, @request_polish_draft_token %>
      <div class="request-compose__row">
        <div class="request-compose__avatar-slot" aria-hidden="true">
          <%= render "shared/user_avatar_icon", variant: :card %>
        </div>

        <div class="request-compose__fields">
          <%= f.text_field :title, placeholder: "例）パンチ力を上げたい", class: "request-compose__title", autocomplete: "off", data: { "request-polish-target": "title" } %>

          <%= f.text_area :body, placeholder: "例）パンチ力を上げるにはどういうトレーニングをしたらいいですか？", rows: 8, class: "request-compose__body", data: { "request-polish-target": "body", action: "input->request-polish#onBodyInput" } %>

          <div class="request-compose__polish">
            <div class="request-compose__polish-actions">
              <button type="button" class="menu-btn menu-btn--ghost request-compose__polish-button" data-request-polish-target="polishButton" data-action="request-polish#polish" disabled>文章を整える</button>
              <p class="request-compose__polish-meta">残り <span data-request-polish-target="attempts"><%= @remaining_polish_attempts %></span> 回</p>
            </div>
            <p class="request-compose__polish-error" data-request-polish-target="error" hidden></p>

            <div class="request-compose__proposal" data-request-polish-target="proposal" hidden>
              <p class="request-compose__proposal-label">AIからの提案</p>
              <p class="request-compose__proposal-title" data-request-polish-target="proposalTitle"></p>
              <p class="request-compose__proposal-body" data-request-polish-target="proposalBody"></p>
              <div class="request-compose__proposal-actions">
                <button type="button" class="menu-btn menu-btn--primary" data-action="request-polish#adopt">提案を反映する</button>
              </div>
            </div>
          </div>

          <div class="request-compose__video" data-controller="video-upload-preview">
            <%= f.label :video, "動画（任意）", class: "request-compose__video-label" %>
            <p class="request-compose__video-hint">MP4 / MOV・1本あたり100MBまで</p>
            <%= f.file_field :video,
                  accept: "video/mp4,video/quicktime,.mp4,.mov",
                  class: "request-compose__video-input",
                  data: {
                    "video-upload-preview-target" => "input",
                    action: "change->video-upload-preview#preview"
                  } %>
            <div class="request-compose__video-preview" data-video-upload-preview-target="box" hidden>
              <p class="request-compose__video-preview-label">選択中の動画</p>
              <div class="video-aspect video-aspect--compose-preview" data-controller="video-aspect">
                <video data-video-upload-preview-target="player" data-video-aspect-target="video" data-action="loadedmetadata->video-aspect#layout" controls playsinline class="video-aspect__media"></video>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="request-compose__toolbar">
        <%= link_to "キャンセル", requests_path, class: "request-compose__cancel" %>
        <%= f.submit "投稿する", class: "menu-btn menu-btn--primary request-compose__submit" %>
      </div>
    <% end %>

    <p class="request-compose__footer-link">
      <%= link_to "一覧に戻る", requests_path, class: "menu-btn menu-btn--ghost" %>
    </p>
  </main>
</div>
