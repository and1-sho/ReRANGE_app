<%# トレーナー一覧用サイドバー（行全体がクリック領域） %>
<% requests_index = controller_name == "requests" && action_name == "index" %>
<% home_feed_active = requests_index && params[:filter].blank? %>
<% advised_feed_active = requests_index && params[:filter] == "advised_by_me" %>
<% profile_show_active = current_page?(trainer_path(current_user)) %>
<% profile_edit_active = current_page?(edit_trainer_path(current_user)) %>
<aside class="requests-sidebar" aria-label="メインメニュー">
  <nav class="requests-sidebar__nav">
    <%= link_to requests_path,
          class: "requests-sidebar__link #{"requests-sidebar__link--active" if home_feed_active}",
          aria: (home_feed_active ? { current: "page" } : {}) do %>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="requests-sidebar__link-icon" aria-hidden="true">
        <path fill-rule="evenodd" d="M9.293 2.293a1 1 0 0 1 1.414 0l7 7A1 1 0 0 1 17 11h-1v6a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1v-6H3a1 1 0 0 1-.707-1.707l7-7Z" clip-rule="evenodd" />
      </svg>
      <span class="requests-sidebar__link-label">ホーム</span>
    <% end %>
    <%= link_to requests_path(filter: "advised_by_me"),
          class: "requests-sidebar__link #{"requests-sidebar__link--active" if advised_feed_active}",
          aria: (advised_feed_active ? { current: "page" } : {}) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="requests-sidebar__link-icon" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
      </svg>
      <span class="requests-sidebar__link-label">フィードバック</span>
    <% end %>
    <%= link_to trainer_path(current_user),
          class: "requests-sidebar__link #{"requests-sidebar__link--active" if profile_show_active}",
          aria: (profile_show_active ? { current: "page" } : {}) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="requests-sidebar__link-icon" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.982 18.725A7.488 7.488 0 0 0 12 15.75a7.488 7.488 0 0 0-5.982 2.975m11.963 0a9 9 0 1 0-11.963 0m11.963 0A8.966 8.966 0 0 1 12 21a8.966 8.966 0 0 1-5.982-2.275M15 9.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
      </svg>
      <span class="requests-sidebar__link-label">プロフィールを見る</span>
    <% end %>
    <%= link_to edit_trainer_path(current_user),
          class: "requests-sidebar__link #{"requests-sidebar__link--active" if profile_edit_active}",
          aria: (profile_edit_active ? { current: "page" } : {}) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="requests-sidebar__link-icon" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
      </svg>
      <span class="requests-sidebar__link-label">プロフィールを編集</span>
    <% end %>
  </nav>
</aside>
