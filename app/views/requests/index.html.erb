<div class="requests-page">
  <header class="requests-header">
    <%= link_to app_home_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__name">Re:RANGE</span>
    <% end %>

    <div class="requests-account">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <% if current_user.member? %>
    <% unless current_user.member_profile_completed? %>
      <div class="profile-reminder">
        <p class="profile-reminder__text">プロフィールを設定すると、トレーナーがあなたの状況を理解しやすくなります。</p>
        <%= link_to "プロフィールを設定する", edit_member_path(current_user), class: "menu-btn menu-btn--primary" %>
      </div>
    <% end %>
    <div class="requests-actions">
      <%= link_to "新規リクエストを作成する", new_request_path, class: "menu-btn menu-btn--primary" %>
    </div>
  <% end %>
  <% if current_user.trainer? %>
    <% unless current_user.trainer_profile_completed? %>
      <div class="profile-reminder">
        <p class="profile-reminder__text">プロフィールを設定すると、メンバーがあなたの指導スタイルを把握しやすくなります。</p>
        <%= link_to "プロフィールを設定する", edit_trainer_path(current_user), class: "menu-btn menu-btn--primary" %>
      </div>
    <% end %>
    <div class="requests-actions">
      <%= link_to "すべて", requests_path,
            class: "menu-btn #{params[:filter] == "advised_by_me" ? "menu-btn--ghost" : "menu-btn--primary"}" %>
      <%= link_to "自分がアドバイスしたもの", requests_path(filter: "advised_by_me"),
            class: "menu-btn #{params[:filter] == "advised_by_me" ? "menu-btn--primary" : "menu-btn--ghost"}" %>
    </div>
  <% end %>

  <% if @requests.any? %>
    <div class="requests-list">
      <% @requests.each do |request| %>
        <article class="request-card">
          <%= link_to profile_path_for(request.user), class: "request-card__avatar-link", aria: { label: "#{request.user.name}のプロフィールへ移動" } do %>
            <%= render "shared/user_avatar_icon", variant: :card %>
          <% end %>
          <div class="request-card__body">
            <div class="request-card__header">
              <span class="request-card__name"><%= link_to request.user.name, profile_path_for(request.user) %></span>
              <span class="request-card__dot">・</span>
              <span class="request-card__date">
                <%= request.created_at.strftime("%Y/%m/%d %H:%M") %>
              </span>
              <p class="request-card__status <%= request.advice.present? ? "request-card__status--answered" : "request-card__status--pending" %>">
                <%= request.advice.present? ? "回答済み" : "未回答" %>
              </p>
            </div>

            <h2 class="request-card__title">
              <%= link_to request.title, request_path(request) %>
            </h2>

            <% if request.video.attached? %>
              <div class="request-card__thumb-wrap" data-controller="request-card-thumb">
                <%= link_to request_path(request), class: "request-card__thumb-link", aria: { label: "動画付きリクエスト「#{request.title}」の詳細へ" } do %>
                  <% if request.video_thumbnail.attached? %>
                    <%= image_tag url_for(request.video_thumbnail),
                          alt: "",
                          loading: "lazy",
                          class: "request-card__thumb-img",
                          data: {
                            "request-card-thumb-target" => "image",
                            action: "load->request-card-thumb#onLoad"
                          } %>
                  <% else %>
                    <span class="request-card__thumb-placeholder">
                      <span class="request-card__thumb-placeholder-text">動画</span>
                      <span class="request-card__thumb-placeholder-sub">サムネ準備中</span>
                    </span>
                  <% end %>
                <% end %>
              </div>
            <% end %>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="requests-empty">公開のリクエストはまだありません</p>
  <% end %>
</div>