<div class="requests-page">
  <header class="requests-header">
    <%= link_to root_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__mark"></span>
      <span class="requests-brand__name">Re:Range</span>
    <% end %>

    <div class="requests-account">
      <div class="requests-account__identity">
        <%= render "shared/user_avatar_icon", variant: :header %>
        <span class="requests-account__user">
          <%= current_user.name %>（<%= current_user.role %>）
        </span>
      </div>
      <%= render "shared/notification_bell_link" %>
      <%= link_to "ログアウト", destroy_user_session_path, class: "menu-btn menu-btn--ghost", data: { turbo_method: :delete } %>
    </div>
  </header>

  <% if current_user.member? %>
    <div class="requests-actions">
      <%= link_to "新規リクエストを作成する", new_request_path, class: "menu-btn menu-btn--primary" %>
    </div>
  <% end %>
  <% if current_user.coach? %>
    <div class="requests-actions">
      <%= link_to "すべて", requests_path,
            class: "menu-btn #{params[:filter] == "advised_by_me" ? "menu-btn--ghost" : "menu-btn--primary"}" %>
      <%= link_to "自分がアドバイスしたもの", requests_path(filter: "advised_by_me"),
            class: "menu-btn #{params[:filter] == "advised_by_me" ? "menu-btn--primary" : "menu-btn--ghost"}" %>
    </div>
  <% end %>

  <% if @requests.any? %>
    <div class="requests-list">
      <% @requests.order(created_at: :desc).each do |request| %>
        <article class="request-card">
          <%= render "shared/user_avatar_icon", variant: :card %>
          <div class="request-card__body">
            <div class="request-card__header">
              <span class="request-card__name"><%= request.user.name %></span>
              <span class="request-card__dot">・</span>
              <span class="request-card__date">
                <%= request.created_at.strftime("%Y/%m/%d %H:%M") %>
              </span>
              <p class="request-card__status <%= request.advice.present? ? "request-card__status--answered" : "request-card__status--pending" %>">
                <%= request.advice.present? ? "回答済み" : "未回答" %>
              </p>
            </div>

            <h2 class="request-card__title">
              <%= link_to request.title, request_path(request) %>
            </h2>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <p class="requests-empty">リクエストは登録されていません</p>
  <% end %>
</div>