<% unread_count = current_user.notifications.unread.count %>
<% bell_label = unread_count.positive? ? "通知一覧へ（未読#{unread_count >= 9 ? '9件以上' : "#{unread_count}件"}）" : "通知一覧へ" %>
<%= link_to notifications_path, class: "notification-bell-link", aria: { label: bell_label } do %>
  <span class="notification-bell-link__inner">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="notification-bell-link__icon" aria-hidden="true" focusable="false">
      <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
    </svg>
    <% if unread_count.positive? %>
      <span class="notification-bell-link__badge"><%= unread_count >= 9 ? "9+" : unread_count %></span>
    <% end %>
  </span>
<% end %>
