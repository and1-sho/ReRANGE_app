<div class="auth-page">
  <header class="site-header auth-header">
    <%= link_to app_home_path, class: "site-header__brand-logo" do %>
      <img class="logo-img" src="/images/logo/logo-main.png" alt="10K">
    <% end %>
  </header>

  <main class="auth-layout signup">
    <div class="auth-inner">
      <h1 class="auth-title">新規登録</h1>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="auth-form__field">
          <%= f.label :name, "名前", class: "auth-form__label" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "auth-form__input" %>
        </div>

        <div class="auth-form__field auth-form__select">
          <%= f.label :role, "区分", class: "auth-form__label" %>
          <%= f.select :role, [["メンバー", :member], ["トレーナー", :trainer]], {}, { class: "auth-form__input" } %>
        </div>

        <div class="auth-form__field">
          <%= f.label :email, "メールアドレス", class: "auth-form__label" %>
          <%= f.email_field :email, autocomplete: "email", class: "auth-form__input" %>
        </div>

        <div class="auth-form__field">
          <%= f.label :password, "パスワード", class: "auth-form__label" %>
          <% if @minimum_password_length %>
            <p class="auth-hint">（<%= @minimum_password_length %>文字以上）</p>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", class: "auth-form__input" %>
        </div>

        <div class="auth-form__field">
          <%= f.label :password_confirmation, "パスワード（確認）", class: "auth-form__label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "auth-form__input" %>
        </div>

        <div class="auth-actions">
          <%= f.submit "登録する", class: "menu-btn menu-btn--primary auth-submit" %>
        </div>
      <% end %>

      <p class="auth-links">
        <%= link_to "ログインはこちら", new_user_session_path, class: "auth-links__link" %>
      </p>
    </div>
  </main>
</div>
