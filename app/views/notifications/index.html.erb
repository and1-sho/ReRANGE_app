<div class="requests-page">
  <header class="requests-header">
    <%= link_to app_home_path, class: "requests-brand requests-brand--link" do %>
      <span class="requests-brand__name">Re:RANGE</span>
    <% end %>

    <div class="requests-account">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </header>

  <main class="notifications-main">
    <h1 class="notifications-heading">通知</h1>

    <% if @notifications.any? %>
      <ul class="notifications-list">
        <% @notifications.each do |notification| %>
          <li class="notifications-item">
            <%= link_to request_path(notification.request), class: "notifications-item__link" do %>
              <span class="notifications-item__message"><%= notification.message %></span>
              <time class="notifications-item__time" datetime="<%= notification.created_at.iso8601 %>">
                <%= notification.created_at.strftime("%Y/%m/%d %H:%M") %>
              </time>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="requests-empty">通知はまだありません</p>
    <% end %>

    <p class="request-compose__footer-link">
      <%= link_to "リクエスト一覧に戻る", requests_path, class: "menu-btn menu-btn--ghost" %>
    </p>
  </main>
</div>
