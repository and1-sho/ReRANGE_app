<div class="top-wrap">
  <header class="top-header">
    <%= link_to root_path, class: "logo logo--link" do %>
      <span class="logo-mark"></span>
      <span>Re:RANGE</span>
    <% end %>
    <nav class="menu" aria-label="アカウント">
      <% if user_signed_in? %>
        <%= link_to "リクエスト一覧", requests_path, class: "menu-btn menu-btn--primary" %>
        <%= link_to "ログアウト", destroy_user_session_path, class: "menu-btn menu-btn--ghost", data: { turbo_method: :delete } %>
      <% else %>
        <%= link_to "無料ではじめる", new_user_registration_path, class: "menu-btn menu-btn--primary" %>
        <%= link_to "ログイン", new_user_session_path, class: "menu-btn menu-btn--ghost" %>
      <% end %>
    </nav>
  </header>
  <section class="hero">
    <div>
      <h1>Re:RANGE</h1>
      <p>「強くなる」をアップデートする。</p>
    </div>
  </section>
</div>

