<div class="requests-page layout-feed page-trainers-show">
  <div class="requests-feed-chrome">
    <%= link_to app_home_path, class: "requests-feed-chrome__brand" do %>
      <span class="requests-feed-chrome__brand-name">Re:RANGE</span>
    <% end %>

    <div class="requests-feed-chrome__actions">
      <% if user_signed_in? %>
        <%= render "shared/notification_bell_link" %>
        <%= render "shared/account_menu" %>
      <% else %>
        <%= link_to "無料ではじめる", new_user_registration_path, class: "menu-btn menu-btn--primary" %>
        <%= link_to "ログイン", new_user_session_path, class: "menu-btn menu-btn--ghost" %>
      <% end %>
    </div>
  </div>

  <div class="requests-feed-body">
    <% if user_signed_in? && (current_user.member? || current_user.trainer?) %>
      <% sidebar_partial = current_user.member? ? "requests/member_sidebar" : "requests/trainer_sidebar" %>
      <div class="requests-trainer-layout">
        <%= render sidebar_partial %>

        <div class="requests-trainer-main">
          <div class="requests-feed-stage requests-feed-stage--profile public-profile public-profile--layout-feed">
            <div class="public-profile__header public-profile__header--feed-span">
              <% if @trainer.header_image.attached? %>
                <%= image_tag @trainer.header_image, class: "public-profile__header-image", alt: "#{@trainer.name}のヘッダー画像" %>
              <% else %>
                <div class="public-profile__header-placeholder"></div>
              <% end %>
            </div>

            <div class="requests-feed-column requests-feed-column--stream">
              <div class="public-profile__body public-profile__body--member-layout">
                <%= render "public_details", trainer: @trainer %>
                <section class="public-profile__member-requests" aria-label="<%= @trainer.name %>がアドバイスしたリクエスト">
                  <%= render "requests/feed_list",
                        requests: @trainer_advised_requests,
                        empty_title: "まだ投稿がありません",
                        empty_subcopy: @trainer_advised_feed_empty_subcopy,
                        empty_class: "public-profile__member-requests-empty" %>
                </section>
              </div>
            </div>
            <%= render "profile_side_rail", trainer: @trainer %>
          </div>
          <%= render "shared/requests_feed_aside" %>
        </div>
      </div>
    <% else %>
      <div class="public-profile public-profile--guest">
        <div class="public-profile__header">
          <% if @trainer.header_image.attached? %>
            <%= image_tag @trainer.header_image, class: "public-profile__header-image", alt: "#{@trainer.name}のヘッダー画像" %>
          <% else %>
            <div class="public-profile__header-placeholder"></div>
          <% end %>
        </div>

        <div class="public-profile__body public-profile__body--member-layout">
          <%= render "public_details", trainer: @trainer %>
          <section class="public-profile__member-requests" aria-label="<%= @trainer.name %>がアドバイスしたリクエスト">
            <%= render "requests/feed_list",
                  requests: @trainer_advised_requests,
                  empty_title: "まだ投稿がありません",
                  empty_subcopy: @trainer_advised_feed_empty_subcopy,
                  empty_class: "public-profile__member-requests-empty" %>
          </section>
          <%= render "profile_side_rail", trainer: @trainer, stacked: true %>
        </div>
      </div>
    <% end %>
  </div>
</div>
