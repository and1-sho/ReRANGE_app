<div class="requests-page layout-feed page-advices-edit">
  <div class="requests-feed-chrome">
    <%= link_to app_home_path, class: "requests-feed-chrome__brand" do %>
      <span class="requests-feed-chrome__brand-name">Re:RANGE</span>
    <% end %>
    <div class="requests-feed-chrome__actions">
      <%= render "shared/notification_bell_link" %>
      <%= render "shared/account_menu" %>
    </div>
  </div>

  <div class="requests-feed-body">
    <div class="requests-trainer-layout">
      <%= render "requests/trainer_sidebar" %>

      <div class="requests-trainer-main">
        <div class="requests-feed-stage requests-feed-stage--compose-gap">
          <div class="requests-feed-column requests-feed-column--stream">
            <% unless current_user.trainer_profile_completed? %>
              <div class="profile-reminder">
                <p class="profile-reminder__text">プロフィールを設定すると、メンバーがあなたの指導スタイルを把握しやすくなります。</p>
                <%= link_to "プロフィールを設定", edit_trainer_path(current_user), class: "menu-btn menu-btn--primary" %>
              </div>
            <% end %>

            <main class="request-compose request-compose--modern">
              <h1 class="request-compose__page-heading">アドバイスを編集</h1>

              <% if @advice.errors.any? %>
                <div class="request-compose__errors" role="alert">
                  <ul>
                    <% @advice.errors.full_messages.each do |message| %>
                      <li><%= message %></li>
                    <% end %>
                  </ul>
                </div>
              <% end %>

              <article class="advice-edit-card">
                <header class="advice-edit-card__meta">
                  <div class="advice-edit-card__meta-left">
                    <%= render "shared/user_avatar_icon", variant: :card %>
                    <div>
                      <p class="advice-edit-card__author"><%= @request.user.name %></p>
                      <p class="advice-edit-card__time"><%= social_time_ago(@request.created_at) %></p>
                    </div>
                  </div>
                </header>
                <h2 class="advice-edit-card__title"><%= @request.title %></h2>
                <% if @request.video.attached? %>
                  <div class="advice-edit-card__request-video">
                    <%= render "shared/video_aspect", url: url_for(@request.video), wrapper_class: "video-aspect--request-show" %>
                  </div>
                <% end %>
              </article>

              <%= form_with model: @advice, url: request_advice_path(@request, @advice), method: :patch, local: true, html: { class: "advice-editor", multipart: true }, data: {
                controller: "request-polish",
                "request-polish-endpoint-value": polish_request_advices_path(@request),
                "request-polish-max-attempts-value": 2,
                "request-polish-remaining-attempts-value": @remaining_polish_attempts,
                "request-polish-draft-token-value": @advice_polish_draft_token,
                "request-polish-min-body-length-value": 8,
                "request-polish-body-only-value": true
              } do |f| %>
                <%= hidden_field_tag :advice_polish_draft_token, @advice_polish_draft_token %>

                <div class="advice-editor__toolbar">
                  <div class="advice-editor__toolbar-left">
                    <%= f.file_field :video,
                          accept: "video/mp4,video/quicktime,.mp4,.mov",
                          class: "request-show__inline-file-input",
                          id: "edit_advice_video_input" %>
                    <label class="request-show__inline-media" for="edit_advice_video_input" aria-label="動画をアップロード">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25Z" />
                      </svg>
                    </label>
                  </div>
                  <button type="button" class="advice-editor__polish" data-request-polish-target="polishButton" data-action="request-polish#polish" disabled>文章を整える</button>
                </div>

                <% if @advice.video.attached? %>
                  <div class="request-show__inline-video-preview advice-editor__preview">
                    <video class="request-show__inline-video-preview-media" playsinline muted preload="metadata" src="<%= url_for(@advice.video) %>" controls></video>
                  </div>
                  <label class="request-compose__video-remove advice-editor__remove-video">
                    <%= check_box_tag "advice[remove_video]", "1", false %>
                    動画を削除する
                  </label>
                <% end %>

                <%= f.text_area :body,
                      placeholder: "アドバイスを書いてください...",
                      rows: 8,
                      class: "advice-editor__body",
                      data: { "request-polish-target": "body", action: "input->request-polish#onBodyInput" } %>

                <p class="request-compose__polish-error" data-request-polish-target="error" hidden></p>

                <div class="request-compose__proposal request-compose__proposal--modern" data-request-polish-target="proposal" hidden>
                  <p class="request-compose__proposal-label">AIからの提案</p>
                  <p class="request-compose__proposal-body" data-request-polish-target="proposalBody"></p>
                  <div class="request-compose__proposal-actions">
                    <button type="button" class="menu-btn menu-btn--primary" data-action="request-polish#adopt">提案を反映する</button>
                  </div>
                </div>

                <div class="advice-editor__actions">
                  <%= link_to "キャンセル", request_path(@request), class: "request-show__inline-cancel" %>
                  <%= f.submit "保存", class: "request-show__inline-submit" %>
                </div>
              <% end %>

              <p class="request-compose__footer-link">
                <%= link_to "リクエスト詳細に戻る", request_path(@request), class: "menu-btn menu-btn--ghost" %>
              </p>
            </main>
          </div>
          <div class="requests-feed-aside-spacer" aria-hidden="true"></div>
        </div>
        <%= render "shared/requests_feed_aside" %>
      </div>
    </div>
  </div>
</div>
